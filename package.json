{
  "name": "erp_mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "prestart": "sh -c 'adb reverse tcp:8080 tcp:8080 >/dev/null 2>&1 || true'",
    "prestart:clear": "sh -c 'adb reverse tcp:8080 tcp:8080 >/dev/null 2>&1 || true'",
    "preandroid": "sh -c 'adb reverse tcp:8080 tcp:8080 >/dev/null 2>&1 || true; adb reverse tcp:8081 tcp:8081 >/dev/null 2>&1 || true'",
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check:lines": "node scripts/check-lines.mjs",
    "quality": "npm run typecheck && npm run check:lines",
    "quality:full": "npm run quality && npm run test"
  },
  "dependencies": {
